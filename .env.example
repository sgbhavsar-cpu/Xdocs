# ---- Backend ----
APP_ENV=dev
LOG_LEVEL=INFO
API_BASE_PATH=/api/v1

# Database / cache / storage
DATABASE_URL=postgresql+asyncpg://xdocs:xdocs@postgres:5432/xdocs
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT=http://minio:9000
S3_BUCKET=xdocs-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Auth (host-issued JWT validated via JWKS). In dev these point at the mock-IdP.
JWT_ISSUER=https://mock-idp.local
JWT_AUDIENCE=xdocs
JWT_ALGORITHMS=RS256
JWKS_URL=http://test-host:8080/.well-known/jwks.json

# CORS (host origins allowed to embed the control)
CORS_ALLOWED_ORIGINS=http://localhost:8080

# ---- LLM (Phase 3+; placeholders for now) ----
LLM_PROVIDER=mock
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
LLM_CHAT_MODEL=gpt-4o
LLM_EMBED_MODEL=text-embedding-3-small
LLM_RATE_LIMIT_PER_MIN=60
LLM_MONTHLY_TOKEN_BUDGET=5000000
ARTIFACT_TTL_HOURS=24

# ---- PDF export (Epic E) ----
# mock (no browser) or chromium (headless Chromium via Playwright)
PDF_RENDERER=mock
PDF_CHROMIUM_PATH=
EXPORT_TTL_HOURS=24

# ---- Test host / mock-IdP ----
TEST_HOST_PORT=8080
MOCK_IDP_ISSUER=https://mock-idp.local
MOCK_IDP_AUDIENCE=xdocs
API_PUBLIC_URL=http://localhost:8000
