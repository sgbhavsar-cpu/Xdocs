{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Xdocs: Migrate & seed",
      "type": "shell",
      "command": "alembic upgrade head && python -m app.scripts.seed",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "Xdocs: Frontend watch",
      "type": "shell",
      "command": "pnpm dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Xdocs: Frontend build",
      "type": "shell",
      "command": "pnpm build",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "Xdocs: Backend tests",
      "type": "shell",
      "command": "pytest -q",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "Xdocs: Frontend tests",
      "type": "shell",
      "command": "pnpm test",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    }
  ]
}
