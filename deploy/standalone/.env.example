# Xdocs standalone deployment configuration. Copy to `.env` and edit.

# ---- Database (Docs_-prefixed schema; see schema.sql) ----
POSTGRES_USER=xdocs
POSTGRES_PASSWORD=change-me
POSTGRES_DB=xdocs
# The API connects over the compose network (host "postgres").
DATABASE_URL=postgresql+asyncpg://xdocs:change-me@postgres:5432/xdocs
# Must match the prefix used by schema.sql. The API targets Docs_* tables.
DB_TABLE_PREFIX=Docs_

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Object storage (MinIO) — reserved for media offload ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET=xdocs-media

# ---- Auth: host-issued JWT validated against the host IdP's JWKS ----
JWT_ISSUER=https://idp.example.com
JWT_AUDIENCE=xdocs
JWT_ALGORITHMS=RS256
JWKS_URL=https://idp.example.com/.well-known/jwks.json

# ---- CORS: origins allowed to embed the control ----
CORS_ALLOWED_ORIGINS=https://docs.example.com

# ---- Public base URL of this API (for absolute media URLs) ----
API_PUBLIC_URL=https://docs-api.example.com

# ---- LLM (offline mock by default; set provider + key for real) ----
LLM_PROVIDER=mock
# OPENAI_API_KEY=
